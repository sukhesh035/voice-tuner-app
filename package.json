{
  "name": "voice-tuner-app",
  "version": "1.5.4",
  "license": "MIT",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "prepare": "husky",
    "start:mobile": "nx serve mobile-app",
    "start:api": "nx serve backend-api",
    "build:mobile": "nx build mobile-app --configuration=production",
    "build:api": "nx build backend-api",
    "test": "nx run-many --target=test --all",
    "lint": "nx run-many --target=lint --all",
    "cap:sync": "nx run mobile-app:cap-sync",
    "cap:ios": "nx run mobile-app:cap-open-ios",
    "cap:android": "nx run mobile-app:cap-open-android",
    "cap:generate-assets": "node scripts/generate-assets.mjs",
    "infra:deploy": "nx run infra:deploy-dev",
    "infra:deploy:prod": "nx run infra:deploy-prod",
    "infra:synth": "nx run infra:build",
    "generate-env:dev": "node scripts/generate-env.mjs dev",
    "generate-env:prod": "node scripts/generate-env.mjs prod",
    "dev:api": "tsx --env-file=.env.local apps/backend-api/src/local-server.ts",
    "dev:ui": "nx serve mobile-app --configuration=local",
    "dev": "concurrently --names \"API,UI\" --prefix-colors \"cyan,magenta\" \"pnpm dev:api\" \"pnpm dev:ui\""
  },
  "private": true,
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "lmdb",
      "msgpackr-extract",
      "nx",
      "unrs-resolver"
    ],
    "overrides": {
      "tar": ">=7.5.11",
      "minimatch@<3.1.4": ">=3.1.4",
      "koa@>=3.0.0 <3.1.2": ">=3.1.2",
      "serialize-javascript@<7.0.3": ">=7.0.3",
      "undici@>=7.0.0 <7.24.0": ">=7.24.0",
      "@modelcontextprotocol/sdk@>=1.10.0 <=1.25.3": ">=1.26.0",
      "fast-xml-parser@>=4.0.0-beta.3 <=5.5.5": ">=5.5.6",
      "@xmldom/xmldom@<0.8.12": ">=0.8.12",
      "lodash@>=4.0.0 <=4.17.23": ">=4.18.0",
      "lodash-es@>=4.0.0 <=4.17.23": ">=4.18.0",
      "flatted@<=3.4.1": ">=3.4.2",
      "picomatch": ">=4.0.4",
      "handlebars": ">=4.7.9",
      "node-forge": ">=1.4.0",
      "path-to-regexp@<0.1.13": ">=0.1.13",
      "path-to-regexp@>=8.0.0 <8.4.0": ">=8.4.0"
    }
  },
