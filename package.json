{
  "name": "voice-tuner-app",
  "version": "0.0.0",
  "license": "MIT",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "prepare": "husky",
    "start:mobile": "nx serve mobile-app",
    "start:api": "nx serve backend-api",
    "build:mobile": "nx build mobile-app --configuration=production",
    "build:api": "nx build backend-api",
    "test": "nx run-many --target=test --all",
    "lint": "nx run-many --target=lint --all",
    "cap:sync": "nx run mobile-app:cap-sync",
    "cap:ios": "nx run mobile-app:cap-open-ios",
    "cap:android": "nx run mobile-app:cap-open-android",
    "infra:deploy": "nx run infra:deploy-dev",
    "infra:deploy:prod": "nx run infra:deploy-prod",
    "infra:synth": "nx run infra:build",
    "generate-env:dev": "node scripts/generate-env.mjs dev",
    "generate-env:prod": "node scripts/generate-env.mjs prod"
  },
  "private": true,
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "lmdb",
      "msgpackr-extract",
      "nx",
      "unrs-resolver"
    ]
  },
  "dependencies": {
    "@angular/animations": "~21.0.0",
    "@angular/common": "~21.0.0",
    "@angular/compiler": "~21.0.0",
    "@angular/core": "~21.0.0",
    "@angular/forms": "~21.0.0",
    "@angular/platform-browser": "~21.0.0",
    "@angular/platform-browser-dynamic": "~21.0.0",
    "@angular/router": "~21.0.0",
    "@angular/service-worker": "~21.0.0",
    "@aws-amplify/auth": "^6.0.0",
    "@aws-amplify/core": "^6.0.0",
    "@capacitor/android": "^7.0.0",
    "@capacitor/app": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/haptics": "^7.0.0",
    "@capacitor/ios": "^7.0.0",
    "@capacitor/keyboard": "^7.0.0",
    "@capacitor/status-bar": "^7.0.0",
    "@ionic/angular": "^8.0.0",
    "@ionic/angular-toolkit": "^12.0.0",
    "aws-amplify": "^6.0.0",
    "chart.js": "^4.4.0",
    "ng2-charts": "^6.0.0",
    "pitchy": "^4.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.6.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "~21.0.0",
    "@angular-devkit/core": "~21.0.0",
    "@angular-devkit/schematics": "~21.0.0",
    "@angular/cli": "~21.0.0",
    "@angular/compiler-cli": "~21.0.0",
    "@nx/angular": "^22.0.0",
    "@nx/eslint-plugin": "^22.0.0",
    "@nx/jest": "^22.0.0",
    "@nx/js": "^22.0.0",
    "@nx/node": "^22.0.0",
    "@nx/workspace": "^22.0.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^22.0.0",
    "aws-cdk": "^2.100.0",
    "aws-cdk-lib": "^2.100.0",
    "constructs": "^10.3.0",
    "esbuild": "^0.20.0",
    "eslint": "^9.0.0",
    "husky": "^9.0.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "nx": "^22.0.0",
    "tailwindcss": "^3.4.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "~5.9.0"
  }
}
