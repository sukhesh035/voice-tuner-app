{
  "name": "backend-api",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/backend-api/src",
  "projectType": "application",
  "tags": ["scope:backend", "type:app"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/apps/backend-api"],
      "options": {
        "command": "node_modules/.bin/esbuild apps/backend-api/src/handlers/sessions.handler.ts --bundle --minify --platform=node --target=node22 --format=cjs --external:@aws-sdk/client-dynamodb --external:@aws-sdk/lib-dynamodb --outfile=dist/apps/backend-api/sessions.js && node_modules/.bin/esbuild apps/backend-api/src/handlers/users.handler.ts --bundle --minify --platform=node --target=node22 --format=cjs --external:@aws-sdk/client-dynamodb --external:@aws-sdk/lib-dynamodb --external:@aws-sdk/client-s3 --external:@aws-sdk/s3-request-presigner --outfile=dist/apps/backend-api/users.js && node_modules/.bin/esbuild apps/backend-api/src/handlers/streaks.handler.ts --bundle --minify --platform=node --target=node22 --format=cjs --external:@aws-sdk/client-dynamodb --external:@aws-sdk/lib-dynamodb --outfile=dist/apps/backend-api/streaks.js && node_modules/.bin/esbuild apps/backend-api/src/handlers/classroom.handler.ts --bundle --minify --platform=node --target=node22 --format=cjs --external:@aws-sdk/client-dynamodb --external:@aws-sdk/lib-dynamodb --outfile=dist/apps/backend-api/classroom.js",
        "cwd": "{workspaceRoot}"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": { "lintFilePatterns": ["apps/backend-api/**/*.ts"] }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": { "jestConfig": "apps/backend-api/jest.config.ts" }
    },
    "deploy": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cd apps/infra && npx cdk deploy --require-approval never",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}
