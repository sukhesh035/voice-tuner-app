{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "moduleResolution": "node",
    "noEmit": true,
    "strict": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": false,
    "types": ["node"]
  },
  "include": [
    "apps/**/*.ts",
    "libs/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "tmp",
    "dist",
    "**/*.spec.ts",
    "**/*.test.ts"
  ]
}
